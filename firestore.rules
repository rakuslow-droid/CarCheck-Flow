/**
 * Firestore Security Rules for CarCheck-Flow
 *
 * CORE PHILOSOPHY
 * This ruleset implements a strict user-ownership model designed for a multi-tenant merchant environment.
 * 
 * WEBHOOK SUPPORT
 * To support the LINE Webhook (which operates outside of Firebase Auth), we allow:
 * 1. Public 'get' and 'list' on Merchants (needed to find associated shop data).
 * 2. Public 'create' on Vehicles (needed for incoming document registrations).
 *
 * Security is maintained as 'read' access to vehicles remains strictly locked to the merchant owner.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /merchants/{merchantId} {
      // Allow public read for webhooks to find shop owner data
      allow get, list: if true; 
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && request.resource.data.id == merchantId;
      allow update: if isExistingOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isExistingOwner(resource.data.ownerId);

      match /vehicles/{vehicleId} {
        // Only owners can read vehicle lists or details
        allow get: if isOwner(resource.data.merchantOwnerId);
        allow list: if isSignedIn() && (query.limit <= 100); // Owners must filter by their ID in practice

        // Webhook needs to create vehicles without being signed in.
        // We ensure critical fields are present.
        allow create: if request.resource.data.merchantId == merchantId 
                      && request.resource.data.merchantOwnerId != null;

        allow update: if isExistingOwner(resource.data.merchantOwnerId) 
                      && request.resource.data.merchantOwnerId == resource.data.merchantOwnerId 
                      && request.resource.data.merchantId == resource.data.merchantId;
                      
        allow delete: if isExistingOwner(resource.data.merchantOwnerId);
      }
    }

    match /{path=**}/vehicles/{vehicleId} {
      allow read: if isOwner(resource.data.merchantOwnerId);
    }
  }
}